@model IEnumerable<ECommerce.PL.Models.ViewModels.CategoryFormVM>
@{
    ViewData["Title"] = "Categories";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-tags-fill text-primary me-2"></i>Categories</h3>
        <p class="text-muted mb-0 small">Manage your product categories</p>
    </div>
    <a asp-action="Create" class="btn btn-primary fw-semibold px-4">
        <i class="bi bi-plus-circle me-2"></i> New Category
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white;">
                <tr>
                    <th class="py-3 ps-4">#</th>
                    <th class="py-3">Name</th>
                    <th class="py-3">Description</th>
                    <th class="py-3">Status</th>
                    <th class="py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td class="ps-4 text-muted">#@cat.Id</td>
                        <td class="fw-semibold">@cat.Name</td>
                        <td class="text-muted">@(cat.Description ?? "—")</td>
                        <td>
                            <span class="badge rounded-pill px-3 fw-normal"
                                  style="background:@(cat.IsActive ? "#d1fae5" : "#f1f5f9");
                                             color:@(cat.IsActive ? "#065f46" : "#64748b");">
                                @(cat.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@cat.Id"
                               class="btn btn-sm me-1 fw-semibold"
                               style="background:#ede9fe; color:#5b21b6;">
                                <i class="bi bi-pencil-fill me-1"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post"
                                  class="d-inline" onsubmit="return confirm('Delete this category?')">
                                <button type="submit" class="btn btn-sm fw-semibold"
                                        style="background:#fee2e2; color:#991b1b;">
                                    <i class="bi bi-trash-fill me-1"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>