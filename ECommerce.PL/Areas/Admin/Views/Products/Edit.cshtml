@model ECommerce.PL.Models.ViewModels.ProductFormVM
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-pencil-fill text-primary me-2"></i>Edit Product</h3>
        <p class="text-muted mb-0 small">Update product information</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary fw-semibold">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="card shadow-sm" style="max-width: 750px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-light border-0 fw-bold">$</span>
                        <input asp-for="Price" class="form-control border-0" type="number" step="0.01" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="StockQuantity" class="form-label fw-semibold"></label>
                    <input asp-for="StockQuantity" class="form-control" type="number" />
                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label fw-semibold"></label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label fw-semibold"></label>
                <input asp-for="ImageUrl" class="form-control" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2">
                        <img src="@Model.ImageUrl" height="80" style="border-radius: 10px; object-fit: cover;"
                             onerror="this.style.display='none'" />
                        <small class="text-muted d-block mt-1">Current image</small>
                    </div>
                }
            </div>
            <div class="mb-4 form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
            </div>
            <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold">
                <i class="bi bi-save me-2"></i> Update Product
            </button>
        </form>
    </div>
</div>