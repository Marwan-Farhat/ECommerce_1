@model IEnumerable<ECommerce.PL.Models.ViewModels.ProductListItemVM>
@{
    ViewData["Title"] = "Products";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-box-seam-fill text-primary me-2"></i>Products</h3>
        <p class="text-muted mb-0 small">Manage your store products</p>
    </div>
    <a asp-action="Create" class="btn btn-primary fw-semibold px-4">
        <i class="bi bi-plus-circle me-2"></i> New Product
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white;">
                <tr>
                    <th class="py-3 ps-4">#</th>
                    <th class="py-3">Image</th>
                    <th class="py-3">Name</th>
                    <th class="py-3">Category</th>
                    <th class="py-3">Price</th>
                    <th class="py-3">Stock</th>
                    <th class="py-3">Status</th>
                    <th class="py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr style="@(!p.IsActive ? "opacity: 0.6;" : "")">
                        <td class="ps-4 text-muted">#@p.Id</td>
                        <td>
                            <img src="@(p.ImageUrl ?? "https://via.placeholder.com/50")"
                                 width="50" height="50"
                                 style="object-fit: cover; border-radius: 10px;"
                                 onerror="this.src='https://via.placeholder.com/50'" />
                        </td>
                        <td class="fw-semibold">
                            @p.Name
                            @if (!p.IsActive)
                            {
                                <span class="badge rounded-pill ms-2 fw-normal"
                                      style="background:#fee2e2; color:#991b1b; font-size:0.7rem;">
                                    Inactive
                                </span>
                            }
                        </td>
                        <td>
                            <span class="badge rounded-pill fw-normal px-3"
                                  style="background:#ede9fe; color:#5b21b6;">
                                @p.CategoryName
                            </span>
                        </td>
                        <td class="fw-bold text-primary">$@p.Price.ToString("0.00")</td>
                        <td>
                            <span class="badge rounded-pill px-3 fw-normal"
                                  style="background:@(p.StockQuantity > 0 ? "#d1fae5" : "#fee2e2");
                                             color:@(p.StockQuantity > 0 ? "#065f46" : "#991b1b");">
                                @p.StockQuantity units
                            </span>
                        </td>
                        <td>
                            <span class="badge rounded-pill px-3 fw-normal"
                                  style="background:@(p.IsActive ? "#d1fae5" : "#f1f5f9");
                                             color:@(p.IsActive ? "#065f46" : "#64748b");">
                                @(p.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@p.Id"
                               class="btn btn-sm me-1 fw-semibold"
                               style="background:#ede9fe; color:#5b21b6;">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post"
                                  class="d-inline" onsubmit="return confirm('Delete this product?')">
                                <button type="submit" class="btn btn-sm fw-semibold"
                                        style="background:#fee2e2; color:#991b1b;">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>