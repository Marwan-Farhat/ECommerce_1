@model IEnumerable<ECommerce.PL.Models.ViewModels.ProductListItemVM>
@{
    ViewData["Title"] = "Products";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam"></i> Products</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Product
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>
                            <img src="@(p.ImageUrl ?? "https://via.placeholder.com/50")"
                                 width="50" height="50" style="object-fit: cover;" class="rounded" />
                        </td>
                        <td class="fw-semibold">@p.Name</td>
                        <td><span class="badge bg-secondary">@p.CategoryName</span></td>
                        <td>$@p.Price.ToString("0.00")</td>
                        <td>
                            <span class="badge @(p.StockQuantity > 0 ? "bg-success" : "bg-danger")">
                                @p.StockQuantity
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this product?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
