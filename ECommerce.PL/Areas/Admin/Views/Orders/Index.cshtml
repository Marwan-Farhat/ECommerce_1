@model IEnumerable<ECommerce.PL.Models.ViewModels.AdminOrderListVM>
@{
    ViewData["Title"] = "All Orders";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0"><i class="bi bi-receipt text-primary me-2"></i>All Orders</h3>
        <p class="text-muted mb-0 small">Manage and track customer orders</p>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white;">
                <tr>
                    <th class="py-3 ps-4">Order #</th>
                    <th class="py-3">Customer</th>
                    <th class="py-3">Date</th>
                    <th class="py-3">Items</th>
                    <th class="py-3">Total</th>
                    <th class="py-3">Status</th>
                    <th class="py-3">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-primary">#@order.Id</td>
                        <td>
                            <div class="fw-semibold">@order.CustomerName</div>
                            <small class="text-muted">@order.CustomerEmail</small>
                        </td>
                        <td class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            @order.OrderDate.ToString("MMM dd, yyyy")
                        </td>
                        <td>
                            <span class="badge bg-light text-dark rounded-pill px-3 fw-normal">
                                @order.ItemCount items
                            </span>
                        </td>
                        <td class="fw-bold">$@order.TotalAmount.ToString("0.00")</td>
                        <td>
                            <span class="badge rounded-pill px-3 py-2 fw-normal badge-status-@order.Status">
                                @order.StatusDisplay
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id"
                               class="btn btn-sm fw-semibold"
                               style="background:#ede9fe; color:#5b21b6; border-radius: 8px;">
                                <i class="bi bi-eye me-1"></i> View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>