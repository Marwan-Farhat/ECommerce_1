@model IEnumerable<ECommerce.PL.Models.ViewModels.AdminOrderListVM>
@{
    ViewData["Title"] = "All Orders";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4"><i class="bi bi-receipt"></i> All Orders</h2>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td>
                            <div>@order.CustomerName</div>
                            <small class="text-muted">@order.CustomerEmail</small>
                        </td>
                        <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td>@order.ItemCount</td>
                        <td class="fw-bold text-primary">$@order.TotalAmount.ToString("0.00")</td>
                        <td><span class="badge bg-primary">@order.StatusDisplay</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
