@model ECommerce.PL.Models.ViewModels.OrderDetailsVM
@using ECommerce.DAL.Entities
@{
    ViewData["Title"] = $"Order #{Model.Id}";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">
            <i class="bi bi-receipt text-primary me-2"></i> Order #@Model.Id
        </h3>
        <span class="badge rounded-pill px-3 py-2 mt-1 badge-status-@Model.Status">
            @Model.StatusDisplay
        </span>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary fw-semibold">
        <i class="bi bi-arrow-left me-1"></i> Back to Orders
    </a>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header border-0 py-3"
                 style="background: linear-gradient(135deg, #6366f1, #4f46e5);">
                <h5 class="mb-0 text-white fw-bold">
                    <i class="bi bi-box-seam me-2"></i> Order Items
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Product</th>
                            <th>Price</th>
                            <th>Qty</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">@item.ProductName</td>
                                <td class="text-muted">$@item.UnitPrice.ToString("0.00")</td>
                                <td>
                                    <span class="badge bg-light text-dark rounded-pill px-3">
                                        x@item.Quantity
                                    </span>
                                </td>
                                <td class="fw-bold text-primary">$@item.SubTotal.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold ps-4">Total:</td>
                            <td class="fw-bold text-primary fs-5">$@Model.TotalAmount.ToString("0.00")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-arrow-repeat text-primary me-2"></i> Update Status
                </h6>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-2">Current Status:</p>
                <span class="badge rounded-pill px-3 py-2 mb-3 badge-status-@Model.Status">
                    @Model.StatusDisplay
                </span>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    <select name="NewStatus" class="form-select mb-3 shadow-sm border-0">
                        @foreach (OrderStatus status in Enum.GetValues<OrderStatus>())
                        {
                            <option value="@((int)status)" selected="@(status == Model.Status)">
                                @status
                            </option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary w-100 fw-semibold">
                        <i class="bi bi-check-circle me-1"></i> Update Status
                    </button>
                </form>

                @if (Model.Status != OrderStatus.Cancelled)
                {
                    <hr />
                    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Cancel this order and restore stock?')">
                        <button type="submit" class="btn w-100 fw-semibold"
                                style="background:#fee2e2; color:#991b1b; border-radius:10px;">
                            <i class="bi bi-x-circle-fill me-2"></i> Cancel Order
                        </button>
                    </form>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-geo-alt-fill text-primary me-2"></i> Shipping Address
                </h6>
            </div>
            <div class="card-body">
                <p class="fw-bold mb-1">@Model.ShippingAddress.FullName</p>
                <p class="text-muted mb-1">@Model.ShippingAddress.Street</p>
                <p class="text-muted mb-1">
                    @Model.ShippingAddress.City, @Model.ShippingAddress.State @Model.ShippingAddress.PostalCode
                </p>
                <p class="text-muted mb-0">@Model.ShippingAddress.Country</p>
            </div>
        </div>
    </div>
</div>