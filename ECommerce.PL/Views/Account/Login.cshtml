@{
    ViewData["Title"] = "Login";
}

<style>
    .min-vh-75 {
        min-height: 75vh;
    }

    .form-control:focus, .form-check-input:focus {
        box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
        border-color: #6366f1;
    }

    .form-check-input:checked {
        background-color: #6366f1;
        border-color: #6366f1;
    }
</style>

@section Scripts {
    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}

<div class="row min-vh-75 align-items-center justify-content-center py-5">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-lg overflow-hidden" style="border-radius: 24px;">
            <div class="row g-0">
                <!-- Left Panel -->
                <div class="col-md-5 d-none d-md-flex flex-column justify-content-center align-items-center p-5 text-white"
                     style="background: linear-gradient(160deg, #6366f1 0%, #3730a3 100%);">
                    <i class="bi bi-bag-heart-fill mb-4" style="font-size: 4rem; opacity: 0.9;"></i>
                    <h3 class="fw-black text-center mb-2">Welcome Back!</h3>
                    <p class="text-center opacity-75 small">
                        Login to access your orders, wishlist, and personalized experience.
                    </p>
                    <hr class="w-50 opacity-25 my-4" />
                    <p class="text-center opacity-60 small mb-1">Don't have an account?</p>
                    <a asp-controller="Account" asp-action="Register"
                       class="btn btn-outline-light btn-sm fw-semibold px-4 mt-1"
                       style="border-radius: 50px;">
                        Create Account
                    </a>
                </div>

                <!-- Right Panel (Form) -->
                <div class="col-md-7 p-5">
                    <div class="mb-4">
                        <h4 class="fw-black mb-1" style="color: #1e1b4b;">Sign In</h4>
                        <p class="text-muted small mb-0">Enter your credentials to continue</p>
                    </div>

                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div asp-validation-summary="All"
                             class="alert small py-2 mb-3"
                             style="background:#fee2e2; color:#991b1b; border:none; border-radius:10px;">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase"
                                   style="letter-spacing:0.5px; color:#64748b;">
                                Email Address
                            </label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text border-0 bg-light">
                                    <i class="bi bi-envelope" style="color:#6366f1;"></i>
                                </span>
                                <input type="email" name="email"
                                       class="form-control border-0 bg-light py-3"
                                       placeholder="example@email.com" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-uppercase"
                                   style="letter-spacing:0.5px; color:#64748b;">
                                Password
                            </label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text border-0 bg-light">
                                    <i class="bi bi-lock" style="color:#6366f1;"></i>
                                </span>
                                <input type="password" name="password" id="passwordInput"
                                       class="form-control border-0 bg-light py-3"
                                       placeholder="••••••••" required />
                                <button type="button" class="input-group-text border-0 bg-light"
                                        onclick="togglePassword()">
                                    <i class="bi bi-eye" id="eyeIcon" style="color:#94a3b8;"></i>
                                </button>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check mb-0">
                                <input type="checkbox" name="rememberMe"
                                       class="form-check-input" id="rememberMe"
                                       style="border-color:#6366f1;" />
                                <label class="form-check-label small text-muted" for="rememberMe">
                                    Remember me
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn w-100 py-3 fw-bold text-white mb-3"
                                style="background: linear-gradient(135deg, #6366f1, #4f46e5);
                                       border-radius: 12px; font-size: 1rem;
                                       box-shadow: 0 8px 20px rgba(99,102,241,0.4);">
                            <i class="bi bi-box-arrow-in-right me-2"></i> Sign In
                        </button>

                        <p class="text-center text-muted small d-md-none mb-0">
                            Don't have an account?
                            <a asp-controller="Account" asp-action="Register"
                               class="fw-semibold text-decoration-none"
                               style="color:#6366f1;">Register</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

