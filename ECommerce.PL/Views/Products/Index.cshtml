@model ECommerce.PL.Models.ViewModels.ProductListVM
@{
    ViewData["Title"] = "Shop";
}

<div class="row">
    <!-- Sidebar -->
    <div class="col-lg-3 mb-4">
        <div class="card shadow-sm sticky-top" style="top: 20px;">
            <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #6366f1, #4f46e5);">
                <h6 class="mb-0 text-white fw-bold">
                    <i class="bi bi-funnel-fill me-2"></i> Filters
                </h6>
            </div>
            <div class="card-body p-3">
                <form asp-action="Index" method="get">
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Search</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="q" value="@Model.Search"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="Search products..." />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Category</label>
                        <div class="d-flex flex-wrap gap-1">
                            <a asp-action="Index" asp-route-q="@Model.Search" asp-route-sort="@Model.Sort"
                               class="badge rounded-pill text-decoration-none py-2 px-3
                                      @(Model.CategoryId == null ? "bg-primary" : "bg-light text-dark")">
                                All
                            </a>
                            @foreach (var cat in Model.Categories)
                            {
                                <a asp-action="Index" asp-route-categoryId="@cat.Id"
                                   asp-route-q="@Model.Search" asp-route-sort="@Model.Sort"
                                   class="badge rounded-pill text-decoration-none py-2 px-3
                                              @(Model.CategoryId == cat.Id ? "bg-primary" : "bg-light text-dark")">
                                    @cat.Name
                                </a>
                            }
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Sort By</label>
                        <select name="sort" class="form-select" onchange="this.form.submit()">
                            <option value="" selected="@(Model.Sort == null)">? Newest</option>
                            <option value="price_asc" selected="@(Model.Sort == "price_asc")">?? Price: Low to High</option>
                            <option value="price_desc" selected="@(Model.Sort == "price_desc")">?? Price: High to Low</option>
                            <option value="name_asc" selected="@(Model.Sort == "name_asc")">?? Name: A-Z</option>
                        </select>
                    </div>
                    <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    <button type="submit" class="btn btn-primary w-100 fw-semibold">
                        <i class="bi bi-funnel me-1"></i> Apply Filters
                    </button>
                    @if (Model.CategoryId != null || Model.Search != null)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-x-circle me-1"></i> Clear Filters
                        </a>
                    }
                </form>
            </div>
        </div>
    </div>

    <!-- Products Grid -->
    <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h5 class="fw-bold mb-0">
                    @Model.TotalCount <span class="text-muted fw-normal">products found</span>
                </h5>
            </div>
        </div>

        @if (!Model.Products.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted"></i>
                <h4 class="mt-3 fw-bold">No products found</h4>
                <p class="text-muted">Try a different search or category.</p>
                <a asp-action="Index" class="btn btn-primary px-4">Clear Filters</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col">
                        <div class="card h-100 product-card shadow-sm">
                            <div style="overflow: hidden; height: 200px;">
                                <img src="@(product.ImageUrl ?? "https://picsum.photos/seed/@product.Id/300/200")"
                                     class="card-img-top w-100 h-100"
                                     style="object-fit: cover;"
                                     alt="@product.Name"
                                     onerror="this.src='https://via.placeholder.com/300x200'" />
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <span class="badge rounded-pill mb-2 fw-normal"
                                      style="background:#ede9fe; color:#5b21b6; width:fit-content;">
                                    @product.CategoryName
                                </span>
                                <h6 class="card-title fw-bold mb-1">@product.Name</h6>
                                <p class="card-text text-muted small flex-grow-1 mb-2">
                                    @product.Description.Substring(0, Math.Min(75, product.Description.Length))...
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold fs-5 text-primary">$@product.Price.ToString("0.00")</span>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <span class="badge rounded-pill"
                                              style="background:#d1fae5; color:#065f46;">
                                            <i class="bi bi-check-circle-fill me-1"></i> In Stock
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill"
                                              style="background:#fee2e2; color:#991b1b;">
                                            Out of Stock
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 p-3 pt-0">
                                <a asp-action="Details" asp-route-id="@product.Id"
                                   class="btn btn-primary w-100 fw-semibold">
                                    <i class="bi bi-eye me-1"></i> View Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5">
                    <ul class="pagination justify-content-center gap-1">
                        <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                            <a class="page-link rounded-3 border-0 shadow-sm" asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-q="@Model.Search"
                               asp-route-sort="@Model.Sort">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link rounded-3 border-0 shadow-sm" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-q="@Model.Search"
                                   asp-route-sort="@Model.Sort">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                            <a class="page-link rounded-3 border-0 shadow-sm" asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-q="@Model.Search"
                               asp-route-sort="@Model.Sort">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>