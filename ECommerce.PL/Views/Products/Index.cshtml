@model ECommerce.PL.Models.ViewModels.ProductListVM
@{
    ViewData["Title"] = "Shop";
}

<style>
    .filter-cat-link {
        color: #64748b;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .filter-cat-link:hover {
            background: #f1f5f9;
            color: #1e1b4b;
        }

    .active-cat {
        background: #ede9fe !important;
        color: #5b21b6 !important;
        font-weight: 600;
    }

    .product-card {
        border: none;
        border-radius: 16px;
        transition: all 0.3s;
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(99, 102, 241, 0.15) !important;
        }

            .product-card:hover img {
                transform: scale(1.08);
            }

    .pagination .page-link {
        color: #6366f1;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        border: none;
    }

    .hero-section {
        box-shadow: 0 20px 60px rgba(99, 102, 241, 0.3);
    }
</style>

<!-- Hero Section -->
<div class="hero-section mb-5 rounded-4 p-5 text-white text-center"
     style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 50%, #3730a3 100%); min-height: 220px;">
    <h1 class="fw-black mb-2" style="font-size: 2.8rem; letter-spacing: -1px;">
        Discover Amazing Products
    </h1>
    <p class="mb-4 opacity-75 fs-5">Find everything you need, all in one place</p>
    <form asp-action="Index" method="get" class="d-flex justify-content-center">
        <div class="input-group shadow-lg" style="max-width: 500px; border-radius: 50px; overflow: hidden;">
            <input type="text" name="q" value="@Model.Search"
                   class="form-control border-0 ps-4 py-3"
                   style="font-size: 1rem;"
                   placeholder="Search for products..." />
            <button type="submit" class="btn px-4 fw-semibold"
                    style="background: #fbbf24; color: #1e1b4b; border: none;">
                <i class="bi bi-search me-1"></i> Search
            </button>
        </div>
    </form>
</div>

<div class="row g-4">
    <!-- Sidebar -->
    <div class="col-lg-3">
        <div class="card shadow-sm sticky-top" style="top: 20px; border-radius: 16px;">
            <div class="card-header border-0 py-3"
                 style="background: linear-gradient(135deg, #6366f1, #4f46e5); border-radius: 16px 16px 0 0;">
                <h6 class="mb-0 text-white fw-bold">
                    <i class="bi bi-funnel-fill me-2"></i> Filters
                </h6>
            </div>
            <div class="card-body p-3">
                <form asp-action="Index" method="get" id="filterForm">
                    <!-- Category Filter -->
                    <div class="mb-4">
                        <p class="fw-bold text-muted small text-uppercase mb-2" style="letter-spacing: 1px;">
                            Category
                        </p>
                        <div class="d-flex flex-column gap-1">
                            <a asp-action="Index" asp-route-q="@Model.Search" asp-route-sort="@Model.Sort"
                               class="filter-cat-link d-flex align-items-center gap-2 px-3 py-2 rounded-3 text-decoration-none
                                      @(Model.CategoryId == null ? "active-cat" : "")">
                                <i class="bi bi-grid-fill" style="font-size:0.85rem;"></i>
                                <span>All Categories</span>
                                @if (Model.CategoryId == null)
                                {
                                    <i class="bi bi-check-circle-fill ms-auto" style="color:#6366f1;"></i>
                                }
                            </a>
                            @foreach (var cat in Model.Categories)
                            {
                                <a asp-action="Index" asp-route-categoryId="@cat.Id"
                                   asp-route-q="@Model.Search" asp-route-sort="@Model.Sort"
                                   class="filter-cat-link d-flex align-items-center gap-2 px-3 py-2 rounded-3 text-decoration-none
                                              @(Model.CategoryId == cat.Id ? "active-cat" : "")">
                                    <i class="bi bi-tag" style="font-size:0.85rem;"></i>
                                    <span>@cat.Name</span>
                                    @if (Model.CategoryId == cat.Id)
                                    {
                                        <i class="bi bi-check-circle-fill ms-auto" style="color:#6366f1;"></i>
                                    }
                                </a>
                            }
                        </div>
                    </div>

                    <hr class="my-3" />

                    <!-- Sort Filter -->
                    <div class="mb-4">
                        <p class="fw-bold text-muted small text-uppercase mb-2" style="letter-spacing: 1px;">
                            Sort By
                        </p>
                        <div class="d-flex flex-column gap-1">
                            @{
                                var sortOptions = new[]
                                {
                                                        (value: "",            icon: "bi-stars",         label: "Newest First"),
                                                        (value: "price_asc",   icon: "bi-sort-up",       label: "Price: Low to High"),
                                                        (value: "price_desc",  icon: "bi-sort-down",     label: "Price: High to Low"),
                                                        (value: "name_asc",    icon: "bi-sort-alpha-up", label: "Name: A to Z"),
                                                        };
                            }
                            @foreach (var opt in sortOptions)
                            {
                                var isActive = Model.Sort == opt.value || (opt.value == "" && Model.Sort == null);
                                <a asp-action="Index"
                                   asp-route-sort="@opt.value"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-q="@Model.Search"
                                   class="filter-cat-link d-flex align-items-center gap-2 px-3 py-2 rounded-3 text-decoration-none
                                              @(isActive ? "active-cat" : "")">
                                    <i class="bi @opt.icon" style="font-size:0.85rem;"></i>
                                    <span>@opt.label</span>
                                    @if (isActive)
                                    {
                                        <i class="bi bi-check-circle-fill ms-auto" style="color:#6366f1;"></i>
                                    }
                                </a>
                            }
                        </div>
                    </div>

                    @if (Model.CategoryId != null || Model.Search != null)
                    {
                        <hr class="my-3" />
                        <a asp-action="Index" class="btn w-100 fw-semibold"
                           style="background:#fee2e2; color:#991b1b; border-radius:10px;">
                            <i class="bi bi-x-circle me-1"></i> Clear Filters
                        </a>
                    }
                </form>
            </div>
        </div>
    </div>

    <!-- Products Grid -->
    <div class="col-lg-9">
        <!-- Results Bar -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <span class="fw-bold fs-5">@Model.TotalCount</span>
                <span class="text-muted"> products found</span>
                @if (!string.IsNullOrEmpty(Model.Search))
                {
                    <span class="text-muted"> for "</span>
                    <span class="fw-semibold text-primary">@Model.Search</span>
                    <span class="text-muted">"</span>
                }
            </div>
            @if (Model.TotalPages > 1)
            {
                <span class="text-muted small">
                    Page @Model.CurrentPage of @Model.TotalPages
                </span>
            }
        </div>

        @if (!Model.Products.Any())
        {
            <div class="text-center py-5">
                <div style="font-size: 5rem;">??</div>
                <h4 class="fw-bold mt-3">No products found</h4>
                <p class="text-muted">Try a different search or browse all categories.</p>
                <a asp-action="Index" class="btn btn-primary px-4 fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i> Browse All
                </a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col">
                        <div class="card h-100 product-card shadow-sm">
                            <!-- Image -->
                            <div style="overflow:hidden; height:200px; position:relative;">
                                <img src="@(product.ImageUrl ?? $"https://picsum.photos/seed/{product.Id}/300/200")"
                                     class="w-100 h-100"
                                     style="object-fit:cover; transition: transform 0.4s;"
                                     alt="@product.Name"
                                     onerror="this.src='https://via.placeholder.com/300x200'" />
                                <!-- Stock Badge -->
                                <div style="position:absolute; top:10px; right:10px;">
                                    @if (product.StockQuantity > 0)
                                    {
                                        <span class="badge shadow-sm"
                                              style="background:#d1fae5; color:#065f46; border-radius:8px;">
                                            <i class="bi bi-check-circle-fill me-1"></i> In Stock
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge shadow-sm"
                                              style="background:#fee2e2; color:#991b1b; border-radius:8px;">
                                            Out of Stock
                                        </span>
                                    }
                                </div>
                            </div>

                            <div class="card-body d-flex flex-column p-3">
                                <!-- Category -->
                                <span class="badge rounded-pill fw-normal mb-2"
                                      style="background:#ede9fe; color:#5b21b6; width:fit-content; font-size:0.75rem;">
                                    <i class="bi bi-tag me-1"></i>@product.CategoryName
                                </span>
                                <!-- Name -->
                                <h6 class="card-title fw-bold mb-1 lh-sm">@product.Name</h6>
                                <!-- Description -->
                                <p class="card-text text-muted small flex-grow-1 mb-3" style="line-height:1.5;">
                                    @product.Description.Substring(0, Math.Min(75, product.Description.Length))...
                                </p>
                                <!-- Price -->
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-black text-primary" style="font-size:1.3rem;">
                                        $@product.Price.ToString("0.00")
                                    </span>
                                    <a asp-action="Details" asp-route-id="@product.Id"
                                       class="btn btn-sm fw-semibold px-3"
                                       style="background: linear-gradient(135deg,#6366f1,#4f46e5);
                                                      color:white; border-radius:8px;">
                                        View <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5">
                    <ul class="pagination justify-content-center gap-1">
                        <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                            <a class="page-link border-0 rounded-3 shadow-sm fw-semibold"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-q="@Model.Search"
                               asp-route-sort="@Model.Sort">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link border-0 rounded-3 shadow-sm fw-semibold"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-q="@Model.Search"
                                   asp-route-sort="@Model.Sort">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                            <a class="page-link border-0 rounded-3 shadow-sm fw-semibold"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-q="@Model.Search"
                               asp-route-sort="@Model.Sort">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

