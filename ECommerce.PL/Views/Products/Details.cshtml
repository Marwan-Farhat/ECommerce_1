@model ECommerce.PL.Models.ViewModels.ProductDetailsVM
@{
    ViewData["Title"] = Model.Name;
}

@section Scripts {
    <script>
        function changeQty(delta) {
            const input = document.getElementById('qtyInput');
            const max = parseInt(input.max);
            const min = parseInt(input.min);
            let val = parseInt(input.value) + delta;
            if (val < min) val = min;
            if (val > max) val = max;
            input.value = val;
        }
    </script>
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Products" asp-action="Index"
               class="text-decoration-none fw-semibold" style="color:#6366f1;">
                <i class="bi bi-shop me-1"></i>Shop
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Products" asp-action="Index"
               asp-route-categoryId="@Model.CategoryId"
               class="text-decoration-none" style="color:#6366f1;">
                @Model.CategoryName
            </a>
        </li>
        <li class="breadcrumb-item active fw-semibold text-muted">@Model.Name</li>
    </ol>
</nav>

<div class="card shadow-sm p-0 overflow-hidden" style="border-radius: 24px;">
    <div class="row g-0">
        <!-- Image Side -->
        <div class="col-md-5 position-relative">
            <img src="@(Model.ImageUrl ?? $"https://picsum.photos/seed/{Model.Id}/500/500")"
                 class="w-100 h-100"
                 style="object-fit:cover; min-height: 420px;"
                 alt="@Model.Name"
                 onerror="this.src='https://via.placeholder.com/500x500'" />

            <!-- Overlay Badge -->
            <div style="position:absolute; top:16px; left:16px;">
                @if (Model.InStock)
                {
                    <span class="badge shadow px-3 py-2"
                          style="background:#d1fae5; color:#065f46; border-radius:10px; font-size:0.85rem;">
                        <i class="bi bi-check-circle-fill me-1"></i> In Stock
                    </span>
                }
                else
                {
                    <span class="badge shadow px-3 py-2"
                          style="background:#fee2e2; color:#991b1b; border-radius:10px; font-size:0.85rem;">
                        <i class="bi bi-x-circle-fill me-1"></i> Out of Stock
                    </span>
                }
            </div>
        </div>

        <!-- Details Side -->
        <div class="col-md-7 p-5 d-flex flex-column justify-content-center">
            <!-- Category -->
            <span class="badge rounded-pill fw-normal mb-3 px-3 py-2"
                  style="background:#ede9fe; color:#5b21b6; width:fit-content;">
                <i class="bi bi-tag me-1"></i> @Model.CategoryName
            </span>

            <!-- Name -->
            <h1 class="fw-black mb-2 lh-sm" style="color:#1e1b4b; font-size:2rem;">
                @Model.Name
            </h1>

            <!-- Price -->
            <div class="d-flex align-items-baseline gap-2 mb-4">
                <span class="fw-black" style="font-size:2.2rem; color:#6366f1;">
                    $@Model.Price.ToString("0.00")
                </span>
            </div>

            <!-- Description -->
            <p class="text-muted lh-lg mb-4">@Model.Description</p>

            <!-- Divider -->
            <hr style="border-color:#e2e8f0;" />

            @if (Model.InStock)
            {
                <!-- Stock Info -->
                <div class="d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-box-seam text-muted"></i>
                    <span class="text-muted small">
                        <span class="fw-semibold text-dark">@Model.StockQuantity</span> units available
                    </span>
                </div>

                <!-- Add to Cart -->
                <form asp-controller="Cart" asp-action="Add" method="post">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="d-flex gap-3 align-items-center flex-wrap">
                        <!-- Quantity Selector -->
                        <div class="d-flex align-items-center border rounded-3 shadow-sm overflow-hidden"
                             style="width: fit-content;">
                            <button type="button" onclick="changeQty(-1)"
                                    class="btn border-0 px-3 py-2"
                                    style="background:#f1f5f9; font-size:1.1rem; color:#6366f1;">
                                <i class="bi bi-dash"></i>
                            </button>
                            <input type="number" name="quantity" id="qtyInput"
                                   value="1" min="1" max="@Model.StockQuantity"
                                   class="form-control border-0 text-center fw-bold"
                                   style="width:60px; font-size:1.1rem;"
                                   readonly />
                            <button type="button" onclick="changeQty(1)"
                                    class="btn border-0 px-3 py-2"
                                    style="background:#f1f5f9; font-size:1.1rem; color:#6366f1;">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>

                        <!-- Add to Cart Button -->
                        <button type="submit" class="btn py-2 px-4 fw-bold text-white flex-grow-1"
                                style="background: linear-gradient(135deg, #6366f1, #4f46e5);
                                           border-radius: 12px; font-size: 1rem;
                                           box-shadow: 0 8px 20px rgba(99,102,241,0.35);">
                            <i class="bi bi-cart-plus me-2"></i> Add to Cart
                        </button>
                    </div>
                </form>
            }
            else
            {
                <div class="alert border-0 py-3"
                     style="background:#fee2e2; color:#991b1b; border-radius:12px;">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    This product is currently out of stock.
                </div>
            }

            <hr style="border-color:#e2e8f0;" />

            <!-- Features -->
            <div class="d-flex gap-4 flex-wrap">
                <div class="d-flex align-items-center gap-2 text-muted small">
                    <i class="bi bi-truck" style="color:#6366f1; font-size:1.1rem;"></i>
                    <span>Free Shipping</span>
                </div>
                <div class="d-flex align-items-center gap-2 text-muted small">
                    <i class="bi bi-shield-check" style="color:#6366f1; font-size:1.1rem;"></i>
                    <span>Secure Payment</span>
                </div>
                <div class="d-flex align-items-center gap-2 text-muted small">
                    <i class="bi bi-arrow-counterclockwise" style="color:#6366f1; font-size:1.1rem;"></i>
                    <span>Easy Returns</span>
                </div>
            </div>

            <div class="mt-4">
                <a asp-controller="Products" asp-action="Index"
                   class="btn btn-outline-secondary fw-semibold">
                    <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                </a>
            </div>
        </div>
    </div>
</div>

