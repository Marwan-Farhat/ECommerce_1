@model ECommerce.PL.Models.ViewModels.ProductDetailsVM
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index">Shop</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a>
        </li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row g-5">
    <div class="col-md-5">
        <img src="@(Model.ImageUrl ?? "https://via.placeholder.com/500x400")"
             class="img-fluid rounded shadow" alt="@Model.Name" />
    </div>
    <div class="col-md-7">
        <span class="badge bg-secondary mb-2">@Model.CategoryName</span>
        <h1 class="mb-3">@Model.Name</h1>
        <h2 class="text-primary mb-4">$@Model.Price.ToString("0.00")</h2>

        @if (Model.InStock)
        {
            <span class="badge bg-success mb-3"><i class="bi bi-check-circle"></i> In Stock (@Model.StockQuantity available)</span>
        }
        else
        {
            <span class="badge bg-danger mb-3">Out of Stock</span>
        }

        <p class="lead mb-4">@Model.Description</p>

        @if (Model.InStock)
        {
            <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex gap-3 align-items-center">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="input-group" style="width: 120px;">
                    <span class="input-group-text">Qty</span>
                    <input type="number" name="quantity" value="1" min="1" max="@Model.StockQuantity" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
            </form>
        }

        <hr class="my-4" />
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Continue Shopping
        </a>
    </div>
</div>
