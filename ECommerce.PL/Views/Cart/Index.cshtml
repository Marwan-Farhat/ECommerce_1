@model ECommerce.PL.Models.ViewModels.CartVM
@{
    ViewData["Title"] = "Shopping Cart";
}

<style>
    .cart-item {
        transition: background 0.2s;
    }

        .cart-item:hover {
            background: #fafafa;
        }

        .cart-item:last-child {
            border-bottom: none !important;
        }
</style>

<div class="d-flex align-items-center gap-3 mb-4">
    <h2 class="fw-black mb-0" style="color:#1e1b4b;">
        <i class="bi bi-cart3 text-primary"></i> Shopping Cart
    </h2>
    @if (!Model.IsEmpty)
    {
        <span class="badge rounded-pill px-3 py-2"
              style="background:#ede9fe; color:#5b21b6;">
            @Model.ItemCount item(s)
        </span>
    }
</div>

@if (Model.IsEmpty)
{
    <div class="card shadow-sm text-center py-5" style="border-radius:24px;">
        <div class="card-body py-5">
            <div style="font-size:5rem;">??</div>
            <h4 class="fw-bold mt-3 mb-2" style="color:#1e1b4b;">Your cart is empty</h4>
            <p class="text-muted mb-4">Looks like you haven't added anything yet.</p>
            <a asp-controller="Products" asp-action="Index"
               class="btn py-2 px-5 fw-bold text-white"
               style="background:linear-gradient(135deg,#6366f1,#4f46e5);
                          border-radius:12px;
                          box-shadow:0 8px 20px rgba(99,102,241,0.35);">
                <i class="bi bi-shop me-2"></i> Start Shopping
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <!-- Cart Items -->
        <div class="col-lg-8">
            <div class="card shadow-sm" style="border-radius:20px;">
                <div class="card-header border-0 py-3 px-4"
                     style="background:linear-gradient(135deg,#6366f1,#4f46e5); border-radius:20px 20px 0 0;">
                    <h5 class="mb-0 text-white fw-bold">
                        <i class="bi bi-bag me-2"></i> Your Items
                    </h5>
                </div>
                <div class="card-body p-0">
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center gap-3 p-4 border-bottom cart-item">
                            <!-- Image -->
                            <img src="@(item.ImageUrl ?? "https://via.placeholder.com/80")"
                                 width="80" height="80"
                                 style="object-fit:cover; border-radius:14px; flex-shrink:0;"
                                 alt="@item.ProductName"
                                 onerror="this.src='https://via.placeholder.com/80'" />

                            <!-- Info -->
                            <div class="flex-grow-1 min-w-0">
                                <h6 class="fw-bold mb-1 text-truncate" style="color:#1e1b4b;">
                                    @item.ProductName
                                </h6>
                                <span class="text-muted small">
                                    Unit Price: <strong>$@item.UnitPrice.ToString("0.00")</strong>
                                </span>
                            </div>

                            <!-- Quantity -->
                            <form asp-action="Update" method="post"
                                  class="d-flex align-items-center border rounded-3 shadow-sm overflow-hidden"
                                  style="width:fit-content; flex-shrink:0;">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                        class="btn border-0 px-2 py-1"
                                        style="background:#f1f5f9; color:#6366f1;">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <span class="px-3 fw-bold" style="min-width:36px; text-align:center;">
                                    @item.Quantity
                                </span>
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                        class="btn border-0 px-2 py-1"
                                        style="background:#f1f5f9; color:#6366f1;">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </form>

                            <!-- Subtotal -->
                            <div class="text-end" style="flex-shrink:0; min-width:80px;">
                                <div class="fw-black" style="color:#6366f1; font-size:1.1rem;">
                                    $@item.SubTotal.ToString("0.00")
                                </div>
                            </div>

                            <!-- Remove -->
                            <form asp-action="Remove" method="post" style="flex-shrink:0;">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-sm border-0"
                                        style="background:#fee2e2; color:#991b1b; border-radius:10px; width:36px; height:36px;"
                                        title="Remove">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
                <div class="card-footer border-0 bg-transparent p-4">
                    <a asp-controller="Products" asp-action="Index"
                       class="btn btn-outline-secondary fw-semibold">
                        <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                    </a>
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
            <div class="card shadow-sm" style="border-radius:20px; position:sticky; top:20px;">
                <div class="card-header border-0 py-3 px-4"
                     style="background:linear-gradient(135deg,#6366f1,#4f46e5); border-radius:20px 20px 0 0;">
                    <h5 class="mb-0 text-white fw-bold">
                        <i class="bi bi-receipt me-2"></i> Order Summary
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Subtotal (@Model.ItemCount items)</span>
                        <span class="fw-semibold">$@Model.Total.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Shipping</span>
                        <span class="fw-semibold d-flex align-items-center gap-1"
                              style="color:#065f46;">
                            <i class="bi bi-truck"></i> Free
                        </span>
                    </div>
                    <hr style="border-color:#e2e8f0;" />
                    <div class="d-flex justify-content-between align-items-baseline mb-4">
                        <span class="fw-bold fs-5">Total</span>
                        <span class="fw-black" style="font-size:1.8rem; color:#6366f1;">
                            $@Model.Total.ToString("0.00")
                        </span>
                    </div>

                    <a asp-controller="Orders" asp-action="Checkout"
                       class="btn w-100 py-3 fw-bold text-white mb-2"
                       style="background:linear-gradient(135deg,#6366f1,#4f46e5);
                                  border-radius:12px; font-size:1rem;
                                  box-shadow:0 8px 20px rgba(99,102,241,0.35);">
                        <i class="bi bi-credit-card me-2"></i> Proceed to Checkout
                    </a>

                    <div class="d-flex justify-content-center gap-3 mt-3">
                        <span class="text-muted small d-flex align-items-center gap-1">
                            <i class="bi bi-shield-check" style="color:#6366f1;"></i> Secure
                        </span>
                        <span class="text-muted small d-flex align-items-center gap-1">
                            <i class="bi bi-truck" style="color:#6366f1;"></i> Free Shipping
                        </span>
                        <span class="text-muted small d-flex align-items-center gap-1">
                            <i class="bi bi-arrow-counterclockwise" style="color:#6366f1;"></i> Easy Returns
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

