@model ECommerce.PL.Models.ViewModels.OrderDetailsVM
@using ECommerce.DAL.Entities
@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-receipt text-primary"></i> Order #@Model.Id</h2>
        <span class="badge rounded-pill px-3 py-2 badge-status-@Model.Status">@Model.StatusDisplay</span>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary fw-semibold">
        <i class="bi bi-arrow-left me-1"></i> Back to Orders
    </a>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header border-0 py-3 px-4"
                 style="background: linear-gradient(135deg, #6366f1, #4f46e5);">
                <h5 class="mb-0 text-white fw-bold">
                    <i class="bi bi-box-seam me-2"></i> Order Items
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Product</th>
                            <th>Unit Price</th>
                            <th>Quantity</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold">
                                    <a asp-controller="Products" asp-action="Details"
                                       asp-route-id="@item.ProductId"
                                       class="text-decoration-none text-dark">
                                        @item.ProductName
                                    </a>
                                </td>
                                <td class="text-muted">$@item.UnitPrice.ToString("0.00")</td>
                                <td>
                                    <span class="badge bg-light text-dark rounded-pill px-3">
                                        x@item.Quantity
                                    </span>
                                </td>
                                <td class="fw-bold text-primary">$@item.SubTotal.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold ps-4">Total:</td>
                            <td class="fw-bold text-primary fs-5">$@Model.TotalAmount.ToString("0.00")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Order Info -->
        <div class="card shadow-sm mb-3">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-info-circle text-primary me-2"></i> Order Info
                </h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Date</span>
                    <span class="fw-semibold">@Model.OrderDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Time</span>
                    <span class="fw-semibold">@Model.OrderDate.ToString("HH:mm")</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Status</span>
                    <span class="badge rounded-pill badge-status-@Model.Status">@Model.StatusDisplay</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr />
                    <p class="text-muted small mb-0">
                        <strong>Notes:</strong> @Model.Notes
                    </p>
                }

                @* ? ?? Cancel ????? ?? ?? Pending *@
                @if (Model.Status == OrderStatus.Pending)
                {
                    <hr />
                    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Are you sure you want to cancel this order?')">
                        <button type="submit" class="btn w-100 fw-semibold"
                                style="background:#fee2e2; color:#991b1b; border-radius:10px;">
                            <i class="bi bi-x-circle-fill me-2"></i> Cancel Order
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- Shipping Address -->
        <div class="card shadow-sm">
            <div class="card-header border-0 bg-light py-3">
                <h6 class="mb-0 fw-bold">
                    <i class="bi bi-geo-alt-fill text-primary me-2"></i> Shipping Address
                </h6>
            </div>
            <div class="card-body">
                <p class="fw-bold mb-1">@Model.ShippingAddress.FullName</p>
                <p class="text-muted mb-1">@Model.ShippingAddress.Street</p>
                <p class="text-muted mb-1">
                    @Model.ShippingAddress.City, @Model.ShippingAddress.State @Model.ShippingAddress.PostalCode
                </p>
                <p class="text-muted mb-0">@Model.ShippingAddress.Country</p>
                @if (!string.IsNullOrEmpty(Model.ShippingAddress.Phone))
                {
                    <p class="mt-2 mb-0">
                        <i class="bi bi-telephone-fill text-primary me-1"></i>
                        @Model.ShippingAddress.Phone
                    </p>
                }
            </div>
        </div>
    </div>
</div>