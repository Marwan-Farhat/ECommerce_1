@model IEnumerable<ECommerce.PL.Models.ViewModels.OrderListItemVM>
@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-bag text-primary"></i> My Orders</h2>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div style="font-size: 5rem;">??</div>
        <h4 class="fw-bold mt-3">No orders yet</h4>
        <p class="text-muted">You haven't placed any orders yet.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary px-4 mt-2 fw-semibold">
            <i class="bi bi-shop me-2"></i> Start Shopping
        </a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: white;">
                    <tr>
                        <th class="py-3 ps-4">Order #</th>
                        <th class="py-3">Date</th>
                        <th class="py-3">Items</th>
                        <th class="py-3">Total</th>
                        <th class="py-3">Status</th>
                        <th class="py-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-primary">#@order.Id</td>
                            <td class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i>
                                @order.OrderDate.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                <span class="badge bg-light text-dark rounded-pill fw-normal px-3">
                                    @order.ItemCount item(s)
                                </span>
                            </td>
                            <td class="fw-bold">$@order.TotalAmount.ToString("0.00")</td>
                            <td>
                                <span class="badge rounded-pill px-3 py-2 badge-status-@order.Status">
                                    @order.StatusDisplay
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.Id"
                                   class="btn btn-sm fw-semibold"
                                   style="background:#ede9fe; color:#5b21b6; border-radius: 8px;">
                                    <i class="bi bi-eye me-1"></i> Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}