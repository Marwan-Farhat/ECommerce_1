@model IEnumerable<ECommerce.PL.Models.ViewModels.OrderListItemVM>
@{
    ViewData["Title"] = "My Orders";
}

<h2 class="mb-4"><i class="bi bi-bag"></i> My Orders</h2>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bag-x display-1 text-muted"></i>
        <h4 class="mt-3">No orders yet</h4>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-2">Start Shopping</a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Order #</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="align-middle fw-bold">#@order.Id</td>
                            <td class="align-middle">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td class="align-middle">@order.ItemCount item(s)</td>
                            <td class="align-middle fw-bold text-primary">$@order.TotalAmount.ToString("0.00")</td>
                            <td class="align-middle">
                                <span class="badge badge-status-@order.Status">@order.StatusDisplay</span>
                            </td>
                            <td class="align-middle">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
