@model ECommerce.PL.Models.ViewModels.CheckoutVM
@{
    ViewData["Title"] = "Checkout";
}

<div class="mb-4">
    <h2 class="fw-bold"><i class="bi bi-credit-card text-primary"></i> Checkout</h2>
    <p class="text-muted">Complete your order below</p>
</div>

<form asp-action="Checkout" method="post">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header border-0 py-3"
                     style="background: linear-gradient(135deg, #6366f1, #4f46e5);">
                    <h5 class="mb-0 text-white fw-bold">
                        <i class="bi bi-geo-alt-fill me-2"></i> Shipping Address
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.SavedAddresses.Any())
                    {
                        <p class="fw-semibold text-muted mb-3">Select a saved address:</p>
                        @foreach (var addr in Model.SavedAddresses)
                        {
                            <div class="form-check p-3 mb-2 border rounded-3"
                                 style="cursor:pointer; transition: all 0.2s;"
                                 onmouseover="this.style.borderColor='#6366f1'"
                                 onmouseout="this.style.borderColor='#dee2e6'">
                                <input class="form-check-input" type="radio"
                                       name="SelectedAddressId" id="addr_@addr.Id"
                                       value="@addr.Id" checked="@(addr.IsDefault)" />
                                <label class="form-check-label w-100" for="addr_@addr.Id">
                                    <span class="fw-bold">@addr.FullName</span>
                                    <span class="text-muted d-block small mt-1">
                                        @addr.Street, @addr.City, @addr.State @addr.PostalCode, @addr.Country
                                    </span>
                                </label>
                            </div>
                        }
                        <hr />
                        <div class="form-check p-2">
                            <input class="form-check-input" type="checkbox"
                                   name="UseNewAddress" id="useNew" value="true" />
                            <label class="form-check-label fw-semibold text-primary" for="useNew">
                                <i class="bi bi-plus-circle me-1"></i> Use a new address
                            </label>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="UseNewAddress" value="true" />
                    }

                    <div id="newAddressForm" class="mt-4 @(!Model.SavedAddresses.Any() ? "" : "d-none")">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input asp-for="NewAddress.FullName" class="form-control" placeholder="John Doe" />
                                <span asp-validation-for="NewAddress.FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Street Address</label>
                                <input asp-for="NewAddress.Street" class="form-control" placeholder="123 Main St" />
                                <span asp-validation-for="NewAddress.Street" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">City</label>
                                <input asp-for="NewAddress.City" class="form-control" />
                                <span asp-validation-for="NewAddress.City" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">State</label>
                                <input asp-for="NewAddress.State" class="form-control" />
                                <span asp-validation-for="NewAddress.State" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Postal Code</label>
                                <input asp-for="NewAddress.PostalCode" class="form-control" />
                                <span asp-validation-for="NewAddress.PostalCode" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Country</label>
                                <input asp-for="NewAddress.Country" class="form-control" />
                                <span asp-validation-for="NewAddress.Country" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">
                                    Phone <span class="text-muted fw-normal">(optional)</span>
                                </label>
                                <input asp-for="NewAddress.Phone" class="form-control" placeholder="+1 234 567 890" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm" style="border-radius: 16px;">
                <div class="card-header border-0 py-3"
                     style="background: linear-gradient(135deg, #6366f1, #4f46e5); border-radius: 16px 16px 0 0;">
                    <h5 class="mb-0 text-white fw-bold">
                        <i class="bi bi-receipt me-2"></i> Order Summary
                    </h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Cart.Items)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-4 py-3">
                                <div>
                                    <span class="fw-semibold">@item.ProductName</span>
                                    <small class="d-block text-muted mt-1">
                                        x@item.Quantity &nbsp;×&nbsp; $@item.UnitPrice.ToString("0.00")
                                    </small>
                                </div>
                                <span class="fw-bold text-primary">$@item.SubTotal.ToString("0.00")</span>
                            </li>
                        }
                        <li class="list-group-item d-flex justify-content-between align-items-center px-4 py-3 bg-light">
                            <span class="fw-bold fs-5">Total</span>
                            <span class="fw-bold fs-4 text-primary">$@Model.Cart.Total.ToString("0.00")</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer border-0 p-4" style="border-radius: 0 0 16px 16px;">
                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold fs-5">
                        <i class="bi bi-bag-check-fill me-2"></i> Place Order
                    </button>
                    <p class="text-center text-muted small mt-2 mb-0">
                        <i class="bi bi-shield-check me-1"></i> Secure checkout
                    </p>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const useNewCb = document.getElementById('useNew');
        const newAddrForm = document.getElementById('newAddressForm');
        if (useNewCb) {
            useNewCb.addEventListener('change', function () {
                newAddrForm.classList.toggle('d-none', !this.checked);
            });
        }
    </script>
}