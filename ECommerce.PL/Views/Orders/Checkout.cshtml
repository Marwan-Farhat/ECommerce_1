@model ECommerce.PL.Models.ViewModels.CheckoutVM
@{
    ViewData["Title"] = "Checkout";
}

<h2 class="mb-4"><i class="bi bi-credit-card"></i> Checkout</h2>

<form asp-action="Checkout" method="post">
    <div class="row g-4">
        <!-- Shipping Address -->
        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Shipping Address</h5>
                </div>
                <div class="card-body">
                    @if (Model.SavedAddresses.Any())
                    {
                        <h6 class="mb-3">Select a saved address:</h6>
                        @foreach (var addr in Model.SavedAddresses)
                        {
                            <div class="form-check mb-2 p-3 border rounded">
                                <input class="form-check-input" type="radio" name="SelectedAddressId"
                                       id="addr_@addr.Id" value="@addr.Id"
                                       checked="@(addr.IsDefault)" />
                                <label class="form-check-label" for="addr_@addr.Id">
                                    <strong>@addr.FullName</strong><br />
                                    @addr.Street, @addr.City, @addr.State @addr.PostalCode, @addr.Country
                                </label>
                            </div>
                        }
                        <hr />
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="UseNewAddress" id="useNew" value="true" />
                            <label class="form-check-label" for="useNew"><strong>Use a new address</strong></label>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="UseNewAddress" value="true" />
                    }

                    <div id="newAddressForm" class="mt-3 @(!Model.SavedAddresses.Any() ? "" : "d-none")">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Full Name</label>
                                <input asp-for="NewAddress.FullName" class="form-control" placeholder="John Doe" />
                                <span asp-validation-for="NewAddress.FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Street Address</label>
                                <input asp-for="NewAddress.Street" class="form-control" placeholder="123 Main St" />
                                <span asp-validation-for="NewAddress.Street" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">City</label>
                                <input asp-for="NewAddress.City" class="form-control" />
                                <span asp-validation-for="NewAddress.City" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">State</label>
                                <input asp-for="NewAddress.State" class="form-control" />
                                <span asp-validation-for="NewAddress.State" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Postal Code</label>
                                <input asp-for="NewAddress.PostalCode" class="form-control" />
                                <span asp-validation-for="NewAddress.PostalCode" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Country</label>
                                <input asp-for="NewAddress.Country" class="form-control" />
                                <span asp-validation-for="NewAddress.Country" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Phone (optional)</label>
                                <input asp-for="NewAddress.Phone" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-receipt"></i> Order Summary</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Cart.Items)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <div>
                                    <span class="fw-semibold">@item.ProductName</span>
                                    <small class="d-block text-muted">x@item.Quantity  $@item.UnitPrice.ToString("0.00")</small>
                                </div>
                                <span>$@item.SubTotal.ToString("0.00")</span>
                            </li>
                        }
                        <li class="list-group-item d-flex justify-content-between fw-bold bg-light">
                            <span>Total</span>
                            <span class="text-primary h5 mb-0">$@Model.Cart.Total.ToString("0.00")</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-bag-check"></i> Place Order
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const useNewCb = document.getElementById('useNew');
        const newAddrForm = document.getElementById('newAddressForm');
        if (useNewCb) {
            useNewCb.addEventListener('change', function () {
                newAddrForm.classList.toggle('d-none', !this.checked);
            });
        }
    </script>
}
