<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shopify</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
        }

        body {
            background-color: #f8f9fa;
        }

        .navbar {
            background: linear-gradient(135deg, #1e1b4b, #312e81) !important;
            padding: 12px 0;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.6rem;
            color: #fff !important;
            letter-spacing: -0.5px;
        }

            .navbar-brand span {
                color: #a5b4fc;
            }

        .nav-btn {
            border-radius: 8px;
            padding: 6px 16px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .product-card {
            border: none;
            border-radius: 16px;
            transition: all 0.3s;
            overflow: hidden;
        }

            .product-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.12) !important;
            }

            .product-card .card-img-top {
                transition: transform 0.3s;
            }

            .product-card:hover .card-img-top {
                transform: scale(1.05);
            }

        .badge-status-Pending {
            background-color: #fef3c7;
            color: #92400e;
        }

        .badge-status-Processing {
            background-color: #dbeafe;
            color: #1e40af;
        }

        .badge-status-Shipped {
            background-color: #ede9fe;
            color: #5b21b6;
        }

        .badge-status-Delivered {
            background-color: #d1fae5;
            color: #065f46;
        }

        .badge-status-Cancelled {
            background-color: #fee2e2;
            color: #991b1b;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            border: none;
            border-radius: 8px;
        }

            .btn-primary:hover {
                background: linear-gradient(135deg, #4f46e5, #3730a3);
            }

        footer {
            background: linear-gradient(135deg, #1e1b4b, #312e81) !important;
        }

        .alert {
            border-radius: 12px;
            border: none;
        }

        .alert-success {
            background-color: #d1fae5;
            color: #065f46;
        }

        .alert-danger {
            background-color: #fee2e2;
            color: #991b1b;
        }

        .card {
            border: none;
            border-radius: 16px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Products" asp-action="Index" asp-area="">
                <i class="bi bi-bag-heart-fill"></i> Shopi<span>fy</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto ms-3">
                    <li class="nav-item">
                        <a class="nav-link text-white fw-500" asp-controller="Products" asp-action="Index" asp-area="">
                            <i class="bi bi-shop"></i> Shop
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="btn btn-outline-light nav-btn" asp-controller="Cart" asp-action="Index" asp-area="">
                            <i class="bi bi-cart3"></i> Cart
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="btn btn-warning nav-btn" asp-area="Admin" asp-controller="Products" asp-action="Index">
                                    <i class="bi bi-gear-fill"></i> Admin
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="btn btn-outline-light nav-btn" asp-controller="Orders" asp-action="Index" asp-area="">
                                <i class="bi bi-bag"></i> My Orders
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post">
                                <button class="btn btn-danger nav-btn">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light nav-btn" asp-controller="Account" asp-action="Login" asp-area="">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn nav-btn text-white" style="background:linear-gradient(135deg,#6366f1,#4f46e5)"
                               asp-controller="Account" asp-action="Register" asp-area="">
                                <i class="bi bi-person-plus"></i> Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="py-4">
        <div class="container">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1 fw-bold fs-5"><i class="bi bi-bag-heart-fill"></i> Shopify</p>
            <p class="mb-0 text-white-50 small">&copy; @DateTime.Now.Year Shopify. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>